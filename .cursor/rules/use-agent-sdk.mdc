## Claude Agent SDK 完整用法

```typescript
import { query as agentQuery } from "@anthropic-ai/claude-agent-sdk";
import { getSettingSources } from "./libs/claude-settings.js";
import { loadUserSettings } from "./libs/user-settings.js";

// 让 Agent 直接写文件 — 不要解析文本输出
const prompt = `根据描述生成内容，直接用 Write 工具写入 ${targetPath}`;

for await (const msg of agentQuery({ prompt, options: { ... } })) {
    if (msg.type === "result") console.log("[agent] done:", msg.subtype);
}
```

## Codex Agent SDK 完整用法

```typescript
import { Codex } from "@openai/codex-sdk";
import { getCodexBinaryPath } from "./libs/codex-runner.js";

const codex = new Codex({ codexPathOverride: getCodexBinaryPath() });
const thread = codex.startThread({
    model: "gpt-5.3-codex",
    workingDirectory: cwd,
    sandboxMode: "danger-full-access",
    approvalPolicy: "never",
});
const { events } = await thread.runStreamed(prompt, { signal });
for await (const event of events) { /* handle */ }
```

